# Server-only URL used by the admin session and CMS API boundary.
# Production builds require this value and it must remain server-only.
API_BASE_URL=https://localhost:7171

# Public site API URL for future public-data integration.
NEXT_PUBLIC_API_BASE_URL=https://localhost:7171

# On Node versions that do not automatically use the Windows certificate store,
# uncomment this after trusting the ASP.NET Core development certificate.
# NODE_OPTIONS=--use-system-ca
